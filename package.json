{
  "name": "mcp-playground",
  "version": "1.0.0",
  "description": "Browser-based UI to connect, manage and debug MCP servers without needing an LLM",
  "keywords": ["mcp", "model-context-protocol", "developer-tools", "debugging", "react", "hono", "typescript"],
  "repository": {
    "type": "git",
    "url": "https://github.com/JoseMiguez98/mcp-playground"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names server,client --prefix-colors cyan,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "start": "NODE_ENV=production tsx src/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "^1.6.1",
    "hono": "^4.7.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
